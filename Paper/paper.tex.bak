B4 & Trimmed Mean & \cite{yin2018} \\
B5 & Bulyan & \cite{guerraoui2018} \\
B6 & FLTrust & \cite{cao2021} \\
B7 & FoolsGold & \cite{fung2020} \\
B8 & RFA & \cite{pillutla2022} \\
B9 & DP-FL ($\varepsilon=8$) & \cite{abadi2016} \\
B10 & FLDetector & \cite{zhang2022} \\
